meta {
  name: Get Season List
  type: http
  seq: 6
}

get {
  url: {{baseUrl}}/emby/segment_reporting/season_list?seriesId={{sampleSeriesId}}
  body: none
  auth: none
}

headers {
  X-Emby-Token: {{apiKey}}
}

assert {
  res.status: eq 200
}

tests {
  test("season_list returns an array", function() {
    const rows = res.getBody();
    expect(Array.isArray(rows)).to.be.true;
    if (rows.length > 0) {
      expect(rows[0]).to.have.property("SeasonId");
      expect(rows[0]).to.have.property("SeasonName");
      expect(rows[0]).to.have.property("TotalEpisodes");
      expect(rows[0]).to.have.property("WithIntro");
      expect(rows[0]).to.have.property("WithCredits");
    }
  });
}

docs {
  ## Get Season List

  Returns seasons for a series with coverage stats.

  **Prerequisites:** Set `sampleSeriesId` in your environment.

  **Parameters:**
  - `seriesId` (required) — Series ID

  **Expected Response:**
  Array of objects with:
  - `SeasonId` / `SeasonName`
  - `TotalEpisodes` / `WithIntro` / `WithCredits` — counts

  **Acceptance Criteria:**
  - ✅ Returns array of seasons with episode counts
  - ✅ Coverage stats are accurate
  - ✅ Requires admin authentication
}
