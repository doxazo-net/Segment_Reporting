meta {
  name: Get Item Segments
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/emby/segment_reporting/item_segments?itemId={{sampleItemId}}
  body: none
  auth: none
}

headers {
  X-Emby-Token: {{apiKey}}
}

assert {
  res.status: eq 200
}

tests {
  // Per-marker tick fields are only present when that specific marker exists
  // (HasIntro can be true from IntroEnd alone), so assert stable structural
  // fields; exact tick values are verified on fresh data by seed.sh.
  test("item_segments reflects Has flags", function() {
    const b = res.getBody();
    expect(b).to.have.property("ItemId");
    expect(b).to.have.property("ItemType");
    expect(b).to.have.property("HasIntro");
    expect(b).to.have.property("HasCredits");
  });
}

docs {
  ## Get Item Segments

  Returns full segment detail for a single item (episode or movie).

  **Prerequisites:** Set `sampleItemId` in your environment.

  **Parameters:**
  - `itemId` (required) — Internal item ID

  **Expected Response:**
  A SegmentInfo object with:
  - `ItemId` / `ItemName` / `ItemType`
  - `IntroStartTicks` / `IntroEndTicks` / `CreditsStartTicks`
  - `HasIntro` / `HasCredits`
  - `SeriesName` / `SeasonName` (for episodes)
  - `LibraryName` / `LibraryId`

  **Acceptance Criteria:**
  - ✅ Returns segment info for valid item
  - ✅ Tick values are present if segments exist
  - ✅ Returns error for non-existent item
  - ✅ Requires admin authentication
}
